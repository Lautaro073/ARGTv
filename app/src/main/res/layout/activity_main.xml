<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Title showing current category -->
    <TextView
        android:id="@+id/category_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Todos los canales"
        android:textColor="#FCD116"
        android:textSize="32sp"
        android:textStyle="bold"
        android:padding="24dp" />

    <!-- Channels carousel (big horizontal cards) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/channel_carousel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false" />

    <!-- Category buttons at the bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#121212"
        android:paddingTop="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Categorías"
            android:textColor="#888888"
            android:textSize="14sp"
            android:paddingHorizontal="24dp"
            android:paddingBottom="12dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingBottom="16dp">

            <LinearLayout
                android:id="@+id/category_buttons"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp" />

        </HorizontalScrollView>

    </LinearLayout>

</LinearLayout>